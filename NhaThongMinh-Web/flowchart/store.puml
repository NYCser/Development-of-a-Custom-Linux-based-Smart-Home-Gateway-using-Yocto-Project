@startuml
title Sequence Diagram - Sensor Cache & Rate Limit in Gateway

participant "ESP32 Sensor Node" as ESP32
participant "MQTT Broker" as MQTT
participant "Gateway\n(on_message)" as GW
participant "CACHED_SENSORS" as CACHE
participant "Rate Limit\n(LAST_DB_WRITE)" as RL
participant "ThreadPoolExecutor" as EXEC
database "MongoDB\n(sensor_readings)" as MONGO
database "Firebase Firestore" as FIRE

ESP32 -> MQTT : Publish sensor data
MQTT -> GW : MQTT message (home/room/sensors)

GW -> GW : Parse topic & JSON payload

GW -> CACHE : Update latest sensor values
note right of CACHE
Store newest sensor data
per room (realtime cache)
end note

GW -> RL : Check last write time

alt Write allowed (Δt > DB_WRITE_INTERVAL)
    RL -> EXEC : Submit _task_update_sensors()
    EXEC -> MONGO : Insert sensor history
    EXEC -> FIRE : Update realtime & history
else Write blocked
    note right of RL
    Skip DB write
    (rate limit active)
    end note
end

@enduml
