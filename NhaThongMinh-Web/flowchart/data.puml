@startuml
title Gateway Cache & Rate-Limit Architecture

package "ESP32 Nodes" {
  component Sensors
  component Devices
}

component "MQTT Broker"
component Gateway

database "Firebase Firestore"
database "MongoDB Local"

package "Gateway Cache Layer" {
  component CACHED_SENSORS
  component CACHED_DEVICE_STATES
  component MANUAL_CONTROL_CACHE
  component CACHED_AUTOMATIONS
  component CACHED_SCHEDULES
  component SAFETY_STATE
}

component RATE_LIMIT
component DB_WORKER

Sensors --> "MQTT Broker" : publish sensor data
Devices --> "MQTT Broker" : publish device status

"MQTT Broker" --> Gateway : MQTT messages

Gateway --> CACHED_SENSORS : update
Gateway --> CACHED_DEVICE_STATES : sync state
Gateway --> SAFETY_STATE : safety check

Gateway --> RATE_LIMIT : check interval
RATE_LIMIT --> DB_WORKER : allow write

DB_WORKER --> "MongoDB Local" : store sensor history
DB_WORKER --> "Firebase Firestore" : update realtime data

Gateway --> "Firebase Firestore" : device & wifi status

@enduml
