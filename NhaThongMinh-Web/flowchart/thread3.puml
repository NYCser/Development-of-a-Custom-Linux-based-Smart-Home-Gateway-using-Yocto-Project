@startuml
title Web Control Flow

actor "Web User" as USER
participant "Firebase" as FB
participant "Gateway MQTT" as GW
participant "MQTT Broker" as MQTT

USER -> FB : Toggle device
FB -> GW : on_snapshot()

GW -> GW : Compare cached state
GW -> MQTT : Publish command
GW -> GW : Update MANUAL_CONTROL_CACHE
@enduml
