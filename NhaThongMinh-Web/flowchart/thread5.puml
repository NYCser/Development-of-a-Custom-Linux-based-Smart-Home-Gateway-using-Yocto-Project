@startuml
title Safety Watchdog Flow

participant "Safety Watchdog" as SAFE
participant "Gateway MQTT" as GW
participant "DB Executor" as EXEC
participant "Firebase" as FB
participant "MQTT Broker" as MQTT

SAFE -> GW : Read CACHED_SENSORS

alt Hazard detected
SAFE -> EXEC : submit(_task_save_alert)
EXEC -> FB : Save alert
SAFE -> MQTT : Publish alarm command
end
@enduml
